rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SMARTKISAN SECURITY RULES - PROTOTYPING MODE
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model for all private farming data while 
     * providing shared read access for community and advisory resources. 
     * 
     * Data Structure:
     * - Private Data: Nested under /users/{userId}/... for natural path-based isolation.
     * - Public/Shared Data: Top-level collections for /cropAdvisories, /marketPrices, and /communityPosts.
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: Critical IDs (ownerId, authorId) are denormalized onto documents 
     *    to allow rules to execute without costly get() lookups.
     * 2. Path-to-Data Consistency: For nested resources, we enforce that internal ownership fields 
     *    match the URL path parameters.
     * 3. Prototyping Flexibility: We strictly enforce WHO can write, but we do NOT enforce 
     *    the specific schema (field types/names) of the data being written, allowing for rapid iteration.
     * 4. Public Access: Market prices and crop advisories are readable by all authenticated users 
     *    but are read-only for the client application.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user matches the provided ID and the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the authenticated user matches the document's author field. */
    function isAuthor(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    /** @description Checks if the authenticated user is the author and the document exists. */
    function isExistingAuthor(authorId) {
      return resource != null && isAuthor(authorId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the root User profile.
     * @path /users/{userId}
     * @allow (create) if auth.uid == userId
     * @deny (update) if auth.uid != userId
     * @principle Ensures users can only manage their own profile and forces ID consistency.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for farms owned by a user.
       * @path /users/{userId}/farms/{farmId}
       * @allow (create) if auth.uid == userId and data.ownerId == userId
       * @deny (list) if auth.uid != userId
       * @principle Path-based ownership with denormalized ownerId validation.
       */
      match /farms/{farmId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.ownerId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for irrigation devices within a specific farm.
         * @path /users/{userId}/farms/{farmId}/irrigationDevices/{deviceId}
         * @allow (update) if auth.uid == userId
         * @principle Deeply nested ownership verification via path parameters.
         */
        match /irrigationDevices/{deviceId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.ownerId == userId;
          allow update: if isExistingOwner(userId) && request.resource.data.ownerId == resource.data.ownerId;
          allow delete: if isExistingOwner(userId);

          /**
           * @description Rules for logs of a specific device.
           * @path .../irrigationDevices/{deviceId}/irrigationLogs/{logId}
           * @principle Authorization independence via path and ownerId consistency.
           */
          match /irrigationLogs/{logId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId);
            allow update, delete: if isExistingOwner(userId);
          }

          /**
           * @description Rules for schedules of a specific device.
           * @path .../irrigationDevices/{deviceId}/irrigationSchedules/{scheduleId}
           */
          match /irrigationSchedules/{scheduleId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId);
            allow update, delete: if isExistingOwner(userId);
          }
        }
      }

      /**
       * @description Rules for AI plant disease scans.
       * @path /users/{userId}/diseaseScans/{scanId}
       * @allow (create) if data.userId == auth.uid
       * @principle Ensures users can only view and create their own diagnostic results.
       */
      match /diseaseScans/{scanId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for crop recommendations.
     * @path /cropAdvisories/{advisoryId}
     * @allow (get) if isSignedIn()
     * @deny (write) always (Admin only via console/backend)
     * @principle Provides public read-only access for authenticated users.
     */
    match /cropAdvisories/{advisoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for market prices.
     * @path /marketPrices/{priceId}
     * @allow (list) if isSignedIn()
     * @principle Read-only community resource for market transparency.
     */
    match /marketPrices/{priceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for community posts.
     * @path /communityPosts/{postId}
     * @allow (create) if request.resource.data.authorId == auth.uid
     * @deny (update) if resource.data.authorId != auth.uid
     * @principle Shared discovery with creator-only write permissions.
     */
    match /communityPosts/{postId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isExistingAuthor(resource.data.authorId) && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isExistingAuthor(resource.data.authorId);

      /**
       * @description Rules for comments on posts.
       * @path /communityPosts/{postId}/comments/{commentId}
       */
      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isExistingAuthor(resource.data.authorId) && request.resource.data.authorId == resource.data.authorId;
        allow delete: if isExistingAuthor(resource.data.authorId);
      }
    }
  }
}